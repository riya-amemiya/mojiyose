{
  "name": "mojiyose",
  "version": "0.1.0",
  "description": "Tiny dependency-free converter between Shift_JIS, UTF-8 and UTF-8 without a BOM.",
  "type": "module",
  "license": "MIT",
  "author": "riya-amemiya",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riya-amemiya/mojiyose.git"
  },
  "homepage": "https://github.com/riya-amemiya/mojiyose#readme",
  "bugs": {
    "url": "https://github.com/riya-amemiya/mojiyose/issues"
  },
  "keywords": [
    "shift_jis",
    "shift-jis",
    "sjis",
    "euc-jp",
    "eucjp",
    "iso-2022-jp",
    "jis",
    "utf-8",
    "bom",
    "encoding",
    "charset",
    "japanese",
    "iconv",
    "convert"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./euc-jp": {
      "import": {
        "types": "./dist/euc-jp.d.mts",
        "default": "./dist/euc-jp.mjs"
      },
      "require": {
        "types": "./dist/euc-jp.d.cts",
        "default": "./dist/euc-jp.cjs"
      }
    },
    "./iso-2022-jp": {
      "import": {
        "types": "./dist/iso-2022-jp.d.mts",
        "default": "./dist/iso-2022-jp.mjs"
      },
      "require": {
        "types": "./dist/iso-2022-jp.d.cts",
        "default": "./dist/iso-2022-jp.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "generate:table": "bun run scripts/generate-table.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
